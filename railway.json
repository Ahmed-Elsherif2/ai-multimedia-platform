{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "startCommand": "/bin/sh -c \"cd backend && gunicorn -w 2 -b 0.0.0.0:$PORT --timeout 1200 --max-requests 15 --max-requests-jitter 12 app:app\"",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 900,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}