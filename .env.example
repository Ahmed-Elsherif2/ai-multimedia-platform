# ============================================================
# AI Multimedia Platform — Environment Variables (Example)
# ============================================================
# 1. Copy this file to .env for local development:
#    cp .env.example .env
#
# 2. Fill in your actual values in .env
# 3. Never commit .env to version control!
#
# For Railway: set these as environment variables in the dashboard.
# ============================================================

# ── Environment ──────────────────────────────────────────────
ENVIRONMENT=development          # development | production
DEFAULT_USER=demo_user_123       # Fallback user for single‑user mode

# ── Flask ────────────────────────────────────────────────────
PORT=5000
DEBUG=false
# ⚠️ Generate your own SECRET_KEY:
#    python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# ── Storage ──────────────────────────────────────────────────
DATA_DIR=data                    # On Railway: /app/data
DB_NAME=platform.db

# ── Hugging Face ─────────────────────────────────────────────
# Required for pyannote speaker diarization.
# Get token at https://hf.co/settings/tokens
# Accept model terms at https://hf.co/pyannote/speaker-diarization-3.1
HF_TOKEN=your_hf_token_here

# ── GROQ API (Primary LLM for summarization & RAG) ──────────
# Get API key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant  # Faster, higher rate limits
# Alternatives: llama-3.3-70b-versatile, mixtral-8x7b-32768
GROQ_MAX_SUMMARY_WORDS=500

# ── GPU / Device ─────────────────────────────────────────────
TORCH_DEVICE=auto                # auto | cuda | cpu

# ── ASR (Speech‑to‑Text) ────────────────────────────────────
WHISPER_MODEL=base               # tiny | base | small | medium | large

# ── Speaker Diarization ──────────────────────────────────────
PYANNOTE_MODEL=pyannote/speaker-diarization-3.1

# ── Embeddings & RAG ─────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_TOP_K=6
RAG_CHUNK_SIZE=800

# ── File Upload Limits ──────────────────────────────────────
MAX_CONTENT_MB=500

# ── Storage Management ──────────────────────────────────────
COMPRESS_AUDIO=true
MAX_KEEP_DAYS=7
CLEANUP_INTERVAL=3600